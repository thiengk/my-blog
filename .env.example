# ============================================
# Personal Blog - Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# For local development, the defaults below should work with docker-compose.

# --- Frontend Configuration ---
# Backend API URL (used by frontend to call backend)
# Local: http://localhost:8080
# Production: your backend URL
PUBLIC_API_URL=http://localhost:8080

# --- Server Configuration ---
# Port the Go server listens on
PORT=8080

# Environment: development | production
ENVIRONMENT=development

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:4321,http://localhost:3000

# --- Database (PostgreSQL) ---
# Local: use docker-compose PostgreSQL
# Production: use Neon connection string
DATABASE_URL=postgres://blog_user:blog_password@localhost:5432/blog_dev?sslmode=disable

# Connection pool settings
DB_MAX_CONNS=10
DB_MIN_CONNS=2
DB_MAX_CONN_LIFE=30m

# --- Redis ---
# Local: use docker-compose Redis
# Production: use Upstash Redis URL
REDIS_URL=redis://localhost:6379

# --- Rate Limiting ---
# Max requests per window for public endpoints (views, health)
RATE_LIMIT_PUBLIC=100

# Max requests per window for newsletter endpoints
RATE_LIMIT_NEWSLETTER=10

# Sliding window size (e.g., "1m" = 1 minute, "30s" = 30 seconds)
RATE_LIMIT_WINDOW=1m

# --- Email (SendGrid) ---
# SendGrid API Key (get from https://app.sendgrid.com/settings/api_keys)
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Sender email (must be verified in SendGrid)
EMAIL_FROM=noreply@yourdomain.com

# Sender name
EMAIL_FROM_NAME=Personal Blog

# Your website URL (for email links)
SITE_URL=http://localhost:8080

# --- Meal Scheduler ---
# Shared secret for internal meal payment scheduler (required for /api/meals/* endpoints)
MEAL_GROUP_SECRET=your-meal-group-secret-here

---
import BaseLayout from '../layouts/BaseLayout.astro';
import AudioTranscriber from '../components/AudioTranscriber.svelte';
---

<BaseLayout title="Speech to Text - Chuyển audio thành text">
  <div class="space-y-6">
    <div class="text-center space-y-2">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">
        Chuyển Audio thành Text
      </h1>
      <p class="text-gray-600 dark:text-gray-400 max-w-lg mx-auto">
        Upload nhiều file MP3 (mỗi file dưới 60 giây) và nhận transcript ngay trên trình duyệt.
        Không cần server, dữ liệu không rời khỏi máy bạn.
      </p>
    </div>

    <AudioTranscriber client:load />
  </div>
</BaseLayout>

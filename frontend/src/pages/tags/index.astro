---
/**
 * Tags Index Page
 * Lists all tags with post count.
 * Displays as a tag cloud / grid layout.
 *
 * Validates: Requirements 2.1, 2.2, 2.5
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Get all non-draft blog posts
const allPosts = await getCollection('blog', ({ data }) => {
  return data.draft !== true;
});

// Extract unique tags with post count
const tagMap = new Map<string, number>();
for (const post of allPosts) {
  for (const tag of post.data.tags) {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  }
}

// Sort tags alphabetically
const tags = Array.from(tagMap.entries()).sort((a, b) =>
  a[0].localeCompare(b[0], 'vi')
);
---

<BaseLayout title="Tags" description="Tất cả tags bài viết trên blog.">
  <section>
    <!-- Page Header -->
    <div class="mb-8">
      <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-gray-100 mt-0">
        Tags
      </h1>
      <p class="mt-2 text-lg text-gray-600 dark:text-gray-400">
        Tìm bài viết theo từ khóa.
      </p>
    </div>

    <!-- Tags Cloud -->
    {tags.length > 0 ? (
      <div class="flex flex-wrap gap-3">
        {tags.map(([tag, count]) => (
          <a
            href={`/tags/${tag}`}
            class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full no-underline
                   bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300
                   hover:bg-primary-100 dark:hover:bg-primary-900/50
                   hover:text-primary-700 dark:hover:text-primary-300
                   transition-colors text-sm font-medium"
          >
            <span>#{tag}</span>
            <span class="inline-flex items-center justify-center w-5 h-5 rounded-full text-xs
                         bg-gray-200 dark:bg-gray-700 text-gray-600 dark:text-gray-400">
              {count}
            </span>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-12">
        <p class="text-gray-500 dark:text-gray-400 text-lg">
          Chưa có tag nào.
        </p>
      </div>
    )}
  </section>
</BaseLayout>

---
/**
 * Blog Paginated Pages (Page 2+)
 * Uses Astro's getStaticPaths with paginate() for dynamic pagination.
 * Filters out draft posts and sorts by date descending.
 *
 * Validates: Requirements 1.6, 2.3, 2.4, 2.6
 */
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import Pagination from '../../components/Pagination.astro';
import { isProtectedPost } from '../../lib/password-utils';

export const getStaticPaths = (async ({ paginate }) => {
  const POSTS_PER_PAGE = 6;
  
  // Get all non-draft blog posts, sorted by date descending
  const allPosts = await getCollection('blog', ({ data }) => {
    return data.draft !== true;
  });

  const sortedPosts = allPosts.sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
  );

  return paginate(sortedPosts, { pageSize: POSTS_PER_PAGE });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const currentPage = page.currentPage;
const totalPages = page.lastPage;
const posts = page.data;
---

<BaseLayout
  title={`Blog - Trang ${currentPage}`}
  description={`Danh sách bài viết trang ${currentPage} - Blog cá nhân chia sẻ kinh nghiệm công nghệ và cuộc sống.`}
>
  <section>
    <!-- Page Header -->
    <div class="mb-8">
      <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-gray-100 mt-0">
        Blog
      </h1>
      <p class="mt-2 text-lg text-gray-600 dark:text-gray-400">
        Chia sẻ kinh nghiệm, review khóa học, và câu chuyện cuộc sống.
        {currentPage > 1 && <span class="text-sm ml-2">— Trang {currentPage}</span>}
      </p>
    </div>

    <!-- Blog Posts Grid -->
    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            category={post.data.category}
            tags={post.data.tags}
            coverImage={post.data.coverImage}
            slug={post.slug}
            body={post.body}
            isProtected={isProtectedPost(post.data.password)}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-12">
        <p class="text-gray-500 dark:text-gray-400 text-lg">
          Chưa có bài viết nào. Hãy quay lại sau nhé!
        </p>
      </div>
    )}

    <!-- Pagination -->
    <Pagination
      currentPage={currentPage}
      totalPages={totalPages}
      baseUrl="/blog"
    />
  </section>
</BaseLayout>

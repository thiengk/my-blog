---
/**
 * BlogPostSchema Component
 * Generates JSON-LD structured data for blog posts using the BlogPosting schema.
 *
 * Validates: Requirements 12.5
 */

interface Props {
  title: string;
  description: string;
  date: Date;
  updatedDate?: Date;
  author: string;
  url: string;
  image?: string;
}

const { title, description, date, updatedDate, author, url, image } = Astro.props;

const siteUrl = 'https://blog.example.com';
const siteName = 'Blog';

const resolvedImage = image
  ? image.startsWith('http')
    ? image
    : new URL(image, siteUrl).href
  : undefined;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description,
  datePublished: date.toISOString(),
  dateModified: (updatedDate || date).toISOString(),
  author: {
    '@type': 'Person',
    name: author,
  },
  url: url,
  ...(resolvedImage && { image: resolvedImage }),
  publisher: {
    '@type': 'Organization',
    name: siteName,
    url: siteUrl,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': url,
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

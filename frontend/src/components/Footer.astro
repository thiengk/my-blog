---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-gray-200 dark:border-gray-800 mt-auto">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <!-- Copyright -->
      <p class="text-sm text-gray-600 dark:text-gray-400">
        &copy; {currentYear} Personal Blog. All rights reserved.
      </p>

      <!-- Footer Links -->
      <nav aria-label="Footer navigation">
        <ul class="flex items-center gap-4 sm:gap-6">
          <li>
            <a
              href="/blog"
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
            >
              Blog
            </a>
          </li>
          <li>
            <a
              href="/categories"
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
            >
              Categories
            </a>
          </li>
          <li>
            <a
              href="/tags"
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
            >
              Tags
            </a>
          </li>
          <li>
            <a
              href="/rss.xml"
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
              aria-label="RSS Feed"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="w-4 h-4"
                aria-hidden="true"
              >
                <circle cx="6.18" cy="17.82" r="2.18"/>
                <path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/>
              </svg>
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</footer>

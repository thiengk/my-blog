---
/**
 * TableOfContents Component
 * Displays a sticky sidebar with nested headings (h2, h3, h4) for navigation.
 * Hidden on mobile, shown on desktop (lg: breakpoint).
 * Links to heading anchors within the article.
 *
 * Validates: Requirements 1.3
 */
import type { TOCItem } from '../lib/toc';

interface Props {
  headings: TOCItem[];
}

const { headings } = Astro.props;
---

{headings.length > 0 && (
  <nav
    class="hidden lg:block sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto scrollbar-hide"
    aria-label="Mục lục bài viết"
  >
    <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100 uppercase tracking-wide mb-3 mt-0">
      Mục lục
    </h2>
    <ul class="space-y-1 text-sm border-l-2 border-gray-200 dark:border-gray-700">
      {headings.map((item) => (
        <li>
          <a
            href={`#${item.id}`}
            class="block py-1 pl-3 text-gray-600 dark:text-gray-400 no-underline hover:text-primary-600 dark:hover:text-primary-400 hover:border-l-primary-500 transition-colors"
          >
            {item.text}
          </a>
          {item.children.length > 0 && (
            <ul class="space-y-0.5 ml-3">
              {item.children.map((child) => (
                <li>
                  <a
                    href={`#${child.id}`}
                    class="block py-0.5 pl-3 text-xs text-gray-500 dark:text-gray-500 no-underline hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
                  >
                    {child.text}
                  </a>
                  {child.children.length > 0 && (
                    <ul class="space-y-0.5 ml-3">
                      {child.children.map((subChild) => (
                        <li>
                          <a
                            href={`#${subChild.id}`}
                            class="block py-0.5 pl-3 text-xs text-gray-400 dark:text-gray-600 no-underline hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
                          >
                            {subChild.text}
                          </a>
                        </li>
                      ))}
                    </ul>
                  )}
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </nav>
)}
